apiVersion: v1
kind: Secret
metadata:
  name: sre-agent-secrets
stringData:
  OPENAI_API_KEY: ""
  # Internal cluster URL for Grafana (kube-prometheus-stack default service name)
  GRAFANA_URL: "http://kube-prometheus-stack-grafana.monitoring.svc.cluster.local"
  GRAFANA_API_KEY: ""
  # Internal cluster URL for ArgoCD
  ARGOCD_SERVER: "https://argocd-server.argocd.svc.cluster.local:443"
  ARGOCD_TOKEN: ""
  # Internal cluster URL for MongoDB
  MDB_MCP_CONNECTION_STRING: "mongodb://mongodb-headless.default.svc.cluster.local:27017/sredb?replicaSet=rs0"
  # GitHub fine-grained PAT scoped to a single repo (Contents/Metadata/Pull requests/Actions: Read-only)
  GITHUB_TOKEN: ""
  GITHUB_OWNER: "tezizzm"
  GITHUB_REPO: "sre-platform-services"
